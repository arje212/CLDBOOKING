{
  "version": 2,
  "builds": [
    {
      "src": "trainroom/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/serviceworker.js",
      "dest": "/staticfiles/booking/js/serviceworker.js",
      "headers": {
        "Service-Worker-Allowed": "/",
        "Cache-Control": "no-cache"
      }
    },
    {
      "src": "/manifest.json",
      "dest": "/staticfiles/booking/manifest.json"
    },
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "trainroom/wsgi.py"
    }
  ]
}